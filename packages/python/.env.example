# AgentVerse environment template
# Copy this file to .env.local for local development.

AGENTVERSE_ENV=development
AGENTVERSE_LOG_LEVEL=INFO

# Optional service integrations
HUGGINGFACE_HUB_TOKEN=
WANDB_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Local paths
AGENTVERSE_DATA_DIR=./data
AGENTVERSE_CACHE_DIR=./.cache/agentverse

# Training defaults
AGENTVERSE_DEFAULT_DEVICE=auto
AGENTVERSE_NUM_WORKERS=1
