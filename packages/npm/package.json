    "haptics",
    "robotics",
    "simulation",
    "agents",
    "reinforcement-learning",
    "agentverse"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
